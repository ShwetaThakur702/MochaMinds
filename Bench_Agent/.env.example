POSTGRES_URL=postgresql://localhost/bench_agent
OPENAI_API_KEY=your-openrouter-key-here
OPENAI_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
MOCK_LLM=false

# Microsoft Teams webhook for Take Action notifications (optional)
# Set this to enable the Teams integration button in the dashboard
# Get webhook URL from: Teams channel → ... → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=
