# ── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=

# ── R1: Authoritative SO request date field ───────────────────────────────
# Options: "SO Creation Date" or "SO Submission Date"
# Confirm with Samuel Anandkumar during KT
R1_REQUEST_DATE_FIELD=SO Submission Date

# ── R1: Gap threshold in days ─────────────────────────────────────────────
R1_GAP_DAYS=30

# ── R5: Minimum word count for JD description ────────────────────────────
R5_MIN_WORD_COUNT=50

# ── Reference config file paths (relative to project root) ───────────────
CLUSTER_MAP_PATH=config/cluster_map.csv
CURRENCY_MAP_PATH=config/currency_map.csv
GEO_POLICY_PATH=config/geo_policy.csv

# ── R5: JD Library reference file for grade-based JD lookup ─────────────────
# If present, SOs whose Grade has a matching rich JD in the library will PASS R5.
JD_LIBRARY_PATH=data/JDs_Consolidated_1_-_Copy.xlsx

# ── Google Sheets Export ──────────────────────────────────────────────────
# Set GOOGLE_SHEETS_ENABLED=true once credentials are configured.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_CREDS_PATH=
# Optional: auto-share the sheet with this email after creation
GOOGLE_SHARE_EMAIL=
# ── Recommended: paste your Google Sheet ID here to avoid Drive quota errors ─
# Create ONE blank Google Sheet manually, share it with the service account email,
# then paste the Sheet ID from the URL: docs.google.com/spreadsheets/d/<ID>/edit
# Exports will ADD new tabs to this sheet instead of creating new Drive files.
GOOGLE_SPREADSHEET_ID=

# ── Ops Team Notification (Mock Webhook) ──────────────────────────────────
# Set to a real MS Teams/Slack webhook URL in production.
# For demo, it points to the mock endpoint built into the FastAPI backend.
TEAMS_WEBHOOK_URL=http://localhost:8000/mock/webhook/teams
